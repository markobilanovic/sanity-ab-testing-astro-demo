{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "sanity": ["./node_modules/sanity"],
      "sanity/*": ["./node_modules/sanity/*"],
      "@sanity/types": ["./node_modules/@sanity/types"],
      "@sanity/*": ["./node_modules/@sanity/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
