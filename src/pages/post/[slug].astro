---
import type { SanityDocument } from "@sanity/client";
import Layout from "../../layouts/Layout.astro";
import PortableText from "../../components/PortableText.astro";
import { loadQuery } from "../../sanity/lib/load-query";
import {
  AB_TEST_VARIANT_ROUTES_QUERY,
  POST_SLUGS_QUERY,
  POST_BY_SLUG_QUERY,
  applyAbVariants,
  buildAbStaticPaths,
  resolveAbRouteFromSlug,
  type AbRouteContext,
  type AbRouteProps,
  type AbTestRouteSource,
} from "../../sanity/lib/ab-routing";
import { resolveAbRouteStateForRequest } from "../../sanity/lib/ab-experiments";

export const prerender = true;

export async function getStaticPaths() {
  const [postSlugResult, abTestsResult] = await Promise.all([
    loadQuery<string[]>({
      query: POST_SLUGS_QUERY,
    }),
    loadQuery<AbTestRouteSource[]>({
      query: AB_TEST_VARIANT_ROUTES_QUERY,
    }),
  ]);

  return buildAbStaticPaths(
    postSlugResult.data ?? [],
    abTestsResult.data ?? [],
    "post",
  );
}

type PostDocument = SanityDocument & {
  title: string;
  body?: unknown[];
  slug?: { current?: string };
  relatedPostsSection?: {
    title?: string;
    relatedPosts?: Array<{
      _id?: string;
      _ref?: string;
      title?: string;
      slug?: string;
    }>;
  };
};

type RelatedPost = { _id: string; title: string; slug: string };
type RelatedPostRef = { _id?: string; _ref?: string; title?: string; slug?: string };

const DEFAULT_RELATED_POSTS_TITLE = "Related posts";
const UNTITLED_POST = "Untitled post";
const POSTS_BY_IDS_QUERY = `*[_type == "post" && _id in $ids]{
  _id,
  title,
  "slug": slug.current
}`;

const toNormalizedRelatedPost = (item: {
  _id?: string;
  title?: string;
  slug?: string;
}): RelatedPost | null => {
  const id = item._id?.trim();
  const slug = item.slug?.trim() || "";
  if (!id || !slug) return null;
  return {
    _id: id,
    title: item.title?.trim() || UNTITLED_POST,
    slug,
  };
};

const mergeUniqueRelatedPostsById = (posts: RelatedPost[]): RelatedPost[] => {
  const byId = new Map<string, RelatedPost>();
  posts.forEach((post) => {
    if (!byId.has(post._id)) byId.set(post._id, post);
  });
  return [...byId.values()];
};

const resolveRelatedPosts = async (post: PostDocument): Promise<RelatedPost[]> => {
  const relatedPosts = (post.relatedPostsSection?.relatedPosts ?? []) as RelatedPostRef[];

  const immediateResolvedPosts = relatedPosts
    .map((relatedPost) =>
      toNormalizedRelatedPost({
        _id: relatedPost?._id,
        title: relatedPost?.title,
        slug: relatedPost?.slug,
      }),
    )
    .filter((relatedPost): relatedPost is RelatedPost => Boolean(relatedPost));

  const unresolvedRefIds = relatedPosts
    .map((relatedPost) => relatedPost?._ref?.trim() || "")
    .filter((id) => id.length > 0);

  if (unresolvedRefIds.length === 0) {
    return immediateResolvedPosts;
  }

  const dedupedRefIds = [...new Set(unresolvedRefIds)];
  const unresolvedResult = await loadQuery<
    Array<{ _id?: string; title?: string; slug?: string }>
  >({
    query: POSTS_BY_IDS_QUERY,
    params: { ids: dedupedRefIds },
  });

  const unresolvedById = new Map(
    (unresolvedResult.data ?? [])
      .filter((item) => Boolean(item?._id))
      .map((item) => [item._id as string, item] as const),
  );

  const resolvedFromRefs = unresolvedRefIds
    .map((refId) => unresolvedById.get(refId))
    .map((item) => (item ? toNormalizedRelatedPost(item) : null))
    .filter((relatedPost): relatedPost is RelatedPost => Boolean(relatedPost));

  return mergeUniqueRelatedPostsById([
    ...immediateResolvedPosts,
    ...resolvedFromRefs,
  ]);
};

const resolvePostSlugAndContexts = async (
  routeSlug: string | undefined,
  initialDocumentSlug: string | undefined,
  initialContexts: AbRouteContext[],
  shouldResolveFromRouteSlug: boolean,
): Promise<{
  documentSlug: string | undefined;
  contexts: AbRouteContext[];
}> => {
  if (!routeSlug || !shouldResolveFromRouteSlug) {
    return { documentSlug: initialDocumentSlug, contexts: initialContexts };
  }

  const abResult = await loadQuery<AbTestRouteSource[]>({
    query: AB_TEST_VARIANT_ROUTES_QUERY,
  });
  const resolvedRoute = resolveAbRouteFromSlug(routeSlug, abResult.data ?? [], "post");

  if (!resolvedRoute) {
    return { documentSlug: initialDocumentSlug, contexts: initialContexts };
  }

  return {
    documentSlug: resolvedRoute.documentSlug,
    contexts: resolvedRoute.contexts,
  };
};

const slug = Astro.params.slug;
const routeProps = Astro.props as Partial<AbRouteProps>;
const routeState = resolveAbRouteStateForRequest({
  routeSlug: slug,
  routeProps,
  rewrittenDocumentSlug: Astro.locals.rewrittenDocumentSlug,
  rewrittenDocumentType: Astro.locals.rewrittenDocumentType,
  defaultDocumentType: "post",
  abExperimentsByRouteKey: Astro.locals.abExperimentsByRouteKey,
});

const resolvedRoute = await resolvePostSlugAndContexts(
  slug,
  routeState.documentSlug,
  routeState.contexts,
  routeState.shouldResolveFromRouteSlug,
);

const postSlug = resolvedRoute.documentSlug;
const abRouteContexts = resolvedRoute.contexts;

let post: PostDocument | null = null;
const cacheTags = postSlug ? [`post:${postSlug}`] : [];
let resolvedRelatedPosts: RelatedPost[] = [];
let relatedPostsSectionTitle = DEFAULT_RELATED_POSTS_TITLE;

if (Astro.cache.enabled && cacheTags.length > 0) {
  Astro.cache.set({
    maxAge: 300,
    swr: 900,
    tags: cacheTags,
  });
}

try {
  if (postSlug) {
    const result = await loadQuery<PostDocument>({
      query: POST_BY_SLUG_QUERY,
      params: { slug: postSlug },
    });
    const loadedPost = result.data ?? null;
    post = loadedPost ? applyAbVariants(loadedPost, abRouteContexts) : loadedPost;

    if (post) {
      resolvedRelatedPosts = await resolveRelatedPosts(post);
    }

    relatedPostsSectionTitle =
      post?.relatedPostsSection?.title?.trim() || DEFAULT_RELATED_POSTS_TITLE;
  }
} catch {
  post = null;
}
---

<Layout title={post?.title ?? "Post not found"}>
  {post ? (
    <article>
      <h1>{post.title}</h1>
      <PortableText portableText={post.body ?? []} />
      {resolvedRelatedPosts.length > 0 && (
        <section>
          <h2>{relatedPostsSectionTitle}</h2>
          <ul>
            {resolvedRelatedPosts.map((relatedPost) => (
              <li>
                <a href={`/post/${relatedPost.slug}`}>{relatedPost.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </article>
  ) : (
    <article>
      <h1>Post not found</h1>
      <p>
        Either the slug does not exist, or Sanity is not configured yet in
        `.env`.
      </p>
    </article>
  )}
</Layout>
