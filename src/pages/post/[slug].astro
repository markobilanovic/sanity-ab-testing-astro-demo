---
import type { SanityDocument } from "@sanity/client";
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import PortableText from "../../components/PortableText.astro";
import { loadQuery } from "../../sanity/lib/load-query";

export const getStaticPaths: GetStaticPaths = async () => {
  const result = await loadQuery<string[]>({
    query: `*[_type == "post" && defined(slug.current)].slug.current`,
  });
  const slugs = (result.data ?? []).filter(
    (value): value is string => typeof value === "string" && value.length > 0,
  );

  return slugs.map((value) => ({
    params: { slug: value },
  }));
};

type PostDocument = SanityDocument & {
  title: string;
  body?: unknown[];
  slug?: { current?: string };
};

const slug = Astro.params.slug;
let post: PostDocument | null = null;

try {
  if (slug) {
    const result = await loadQuery<PostDocument>({
      query: `*[_type == "post" && slug.current == $slug][0]{
        _id,
        title,
        body,
        slug
      }`,
      params: { slug },
    });
    post = result.data ?? null;
  }
} catch {
  post = null;
}
---

<Layout title={post?.title ?? "Post not found"}>
  {post ? (
    <article>
      <h1>{post.title}</h1>
      <PortableText portableText={post.body ?? []} />
    </article>
  ) : (
    <article>
      <h1>Post not found</h1>
      <p>
        Either the slug does not exist, or Sanity is not configured yet in
        `.env`.
      </p>
    </article>
  )}
</Layout>
