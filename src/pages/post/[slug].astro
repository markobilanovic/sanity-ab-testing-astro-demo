---
import type { SanityDocument } from "@sanity/client";
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import PortableText from "../../components/PortableText.astro";
import { loadQuery } from "../../sanity/lib/load-query";

export const getStaticPaths: GetStaticPaths = async () => {
  const postResult = await loadQuery<string[]>({
    query: `*[_type == "post" && defined(slug.current)].slug.current`,
  });
  const postSlugs = (postResult.data ?? []).filter(
    (value): value is string => typeof value === "string" && value.length > 0,
  );

  const abResult = await loadQuery<
    Array<{
      _id?: string;
      id?: string;
      variantCodes?: string[];
      referencedPosts?: Array<{ slug?: { current?: string } }>;
    }>
  >({
    query: `*[_type == "abTest" && defined(id)]{
      _id,
      id,
      variantCodes,
      "referencedPosts": *[
        _type == "post" &&
        defined(slug.current) &&
        references(^._id)
      ]{
        slug
      }
    }`,
  });

  const staticPaths: Array<{
    params: { slug: string };
    props: {
      postSlug: string;
      abId: string | null;
      abTestDocId: string | null;
      variantCode: string | null;
    };
  }> = [];
  const seenRouteSlugs = new Set<string>();

  for (const postSlug of postSlugs) {
    if (seenRouteSlugs.has(postSlug)) {
      continue;
    }

    seenRouteSlugs.add(postSlug);
    staticPaths.push({
      params: { slug: postSlug },
      props: {
        postSlug,
        abId: null,
        abTestDocId: null,
        variantCode: null,
      },
    });
  }

  for (const abTest of abResult.data ?? []) {
    const abTestDocId =
      typeof abTest._id === "string" ? abTest._id.trim() : "";
    const abId = typeof abTest.id === "string" ? abTest.id.trim() : "";
    if (!abId || !abTestDocId) {
      continue;
    }

    const referencedPostSlugs = (abTest.referencedPosts ?? [])
      .map((post) => post.slug?.current)
      .filter(
        (value): value is string =>
          typeof value === "string" && value.trim().length > 0,
      );
    const variantCodes = (abTest.variantCodes ?? []).filter(
      (value): value is string =>
        typeof value === "string" && value.trim().length > 0,
    );

    for (const postSlug of referencedPostSlugs) {
      for (const variantCode of variantCodes) {
        const routeSlug = `${postSlug}-${abId}-${variantCode}`;
        if (seenRouteSlugs.has(routeSlug)) {
          continue;
        }

        seenRouteSlugs.add(routeSlug);
        staticPaths.push({
          params: { slug: routeSlug },
          props: {
            postSlug,
            abId,
            abTestDocId,
            variantCode,
          },
        });
      }
    }
  }

  return staticPaths;
};

type PostDocument = SanityDocument & {
  title: string;
  body?: unknown[];
  slug?: { current?: string };
};

const AB_TOGGLE_FIELD_NAME = "showAbVariant";
const AB_VARIANTS_FIELD_NAME = "abVariants";
const AB_TEST_REF_FIELD_NAME = "abTestRef";

type AbRouteContext = {
  abTestDocId: string;
  variantCode: string;
};

function applyAbVariants(value: unknown, context: AbRouteContext): unknown {
  if (Array.isArray(value)) {
    return value.map((item) => applyAbVariants(item, context));
  }

  if (!value || typeof value !== "object") {
    return value;
  }

  const record = value as Record<string, unknown>;
  let nextRecord = record;

  const isAbEnabled = record[AB_TOGGLE_FIELD_NAME] === true;
  const abTestRef = record[AB_TEST_REF_FIELD_NAME] as { _ref?: string } | undefined;
  const variants = record[AB_VARIANTS_FIELD_NAME];

  if (
    isAbEnabled &&
    abTestRef?._ref === context.abTestDocId &&
    Array.isArray(variants)
  ) {
    const matchedVariant = variants.find((variant) => {
      if (!variant || typeof variant !== "object") {
        return false;
      }

      const variantRecord = variant as Record<string, unknown>;
      return variantRecord.variantCode === context.variantCode;
    }) as Record<string, unknown> | undefined;

    const variantContent =
      matchedVariant && typeof matchedVariant.variant === "object"
        ? (matchedVariant.variant as Record<string, unknown>)
        : null;

    if (variantContent) {
      nextRecord = {
        ...record,
        ...variantContent,
      };
    }
  }

  const transformedRecord: Record<string, unknown> = {};
  for (const [key, itemValue] of Object.entries(nextRecord)) {
    transformedRecord[key] = applyAbVariants(itemValue, context);
  }

  return transformedRecord;
}

const slug = Astro.params.slug;
const postSlug =
  typeof Astro.props.postSlug === "string" ? Astro.props.postSlug : slug;
const selectedAbId =
  typeof Astro.props.abId === "string" ? Astro.props.abId : null;
const selectedAbTestDocId =
  typeof Astro.props.abTestDocId === "string" ? Astro.props.abTestDocId : null;
const selectedVariantCode =
  typeof Astro.props.variantCode === "string" ? Astro.props.variantCode : null;
const abRouteContext =
  selectedAbId && selectedAbTestDocId && selectedVariantCode
    ? { abTestDocId: selectedAbTestDocId, variantCode: selectedVariantCode }
    : null;
let post: PostDocument | null = null;

try {
  if (postSlug) {
    const result = await loadQuery<PostDocument>({
      query: `*[_type == "post" && slug.current == $slug][0]{
        _id,
        title,
        body,
        slug,
        showAbVariant,
        abTestRef,
        abVariants
      }`,
      params: { slug: postSlug },
    });
    const loadedPost = result.data ?? null;
    post =
      loadedPost && abRouteContext
        ? (applyAbVariants(loadedPost, abRouteContext) as PostDocument)
        : loadedPost;
  }
} catch {
  post = null;
}
---

<Layout title={post?.title ?? "Post not found"}>
  {post ? (
    <article>
      <h1>{post.title}</h1>
      <PortableText portableText={post.body ?? []} />
    </article>
  ) : (
    <article>
      <h1>Post not found</h1>
      <p>
        Either the slug does not exist, or Sanity is not configured yet in
        `.env`.
      </p>
    </article>
  )}
</Layout>
