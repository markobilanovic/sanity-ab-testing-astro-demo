---
import type { SanityDocument } from "@sanity/client";
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import PortableText from "../../components/PortableText.astro";
import { loadQuery } from "../../sanity/lib/load-query";

export const getStaticPaths: GetStaticPaths = async () => {
  const postResult = await loadQuery<string[]>({
    query: `*[_type == "post" && defined(slug.current)].slug.current`,
  });
  const postSlugs = (postResult.data ?? []).filter(
    (value): value is string => typeof value === "string" && value.length > 0,
  );

  const abResult = await loadQuery<
    Array<{
      id?: string;
      variantCodes?: string[];
      referencedPosts?: Array<{ slug?: { current?: string } }>;
    }>
  >({
    query: `*[_type == "abTest" && defined(id)]{
      id,
      variantCodes,
      "referencedPosts": *[
        _type == "post" &&
        defined(slug.current) &&
        references(^._id)
      ]{
        slug
      }
    }`,
  });

  const staticPaths: Array<{
    params: { slug: string };
    props: { postSlug: string };
  }> = [];
  const seenRouteSlugs = new Set<string>();

  for (const postSlug of postSlugs) {
    if (seenRouteSlugs.has(postSlug)) {
      continue;
    }

    seenRouteSlugs.add(postSlug);
    staticPaths.push({
      params: { slug: postSlug },
      props: { postSlug },
    });
  }

  for (const abTest of abResult.data ?? []) {
    const abId = typeof abTest.id === "string" ? abTest.id.trim() : "";
    if (!abId) {
      continue;
    }

    const referencedPostSlugs = (abTest.referencedPosts ?? [])
      .map((post) => post.slug?.current)
      .filter(
        (value): value is string =>
          typeof value === "string" && value.trim().length > 0,
      );
    const variantCodes = (abTest.variantCodes ?? []).filter(
      (value): value is string =>
        typeof value === "string" && value.trim().length > 0,
    );

    for (const postSlug of referencedPostSlugs) {
      for (const variantCode of variantCodes) {
        const routeSlug = `${postSlug}-${abId}-${variantCode}`;
        if (seenRouteSlugs.has(routeSlug)) {
          continue;
        }

        seenRouteSlugs.add(routeSlug);
        staticPaths.push({
          params: { slug: routeSlug },
          props: { postSlug },
        });
      }
    }
  }

  return staticPaths;
};

type PostDocument = SanityDocument & {
  title: string;
  body?: unknown[];
  slug?: { current?: string };
};

const slug = Astro.params.slug;
const postSlug =
  typeof Astro.props.postSlug === "string" ? Astro.props.postSlug : slug;
let post: PostDocument | null = null;

try {
  if (postSlug) {
    const result = await loadQuery<PostDocument>({
      query: `*[_type == "post" && slug.current == $slug][0]{
        _id,
        title,
        body,
        slug
      }`,
      params: { slug: postSlug },
    });
    post = result.data ?? null;
  }
} catch {
  post = null;
}
---

<Layout title={post?.title ?? "Post not found"}>
  {post ? (
    <article>
      <h1>{post.title}</h1>
      <PortableText portableText={post.body ?? []} />
    </article>
  ) : (
    <article>
      <h1>Post not found</h1>
      <p>
        Either the slug does not exist, or Sanity is not configured yet in
        `.env`.
      </p>
    </article>
  )}
</Layout>
