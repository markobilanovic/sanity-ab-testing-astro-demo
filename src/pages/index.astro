---
import Layout from "../layouts/Layout.astro";
import { loadQuery } from "../sanity/lib/load-query";

type PostListItem = {
  _id: string;
  title: string;
  slug?: { current?: string };
};

let posts: PostListItem[] = [];
let loadError = false;

try {
  const result = await loadQuery<PostListItem[]>({
    query: `*[_type == "post"] | order(publishedAt desc){
      _id,
      title,
      slug
    }`,
  });
  posts = result.data ?? [];
} catch {
  loadError = true;
}
---

<Layout title="Astro + Sanity blog">
  <h1>Astro + Sanity</h1>
  <p>
    Open <a href="/studio">/studio</a> to manage content, then create a post and
    publish it.
  </p>
  {loadError && (
    <p>
      Could not load posts yet. Confirm your Sanity project values in `.env`,
      then refresh.
    </p>
  )}

  {
    posts.length > 0 ? (
      <ul>
        {posts.map((post) => (
          <li>
            <a href={`/post/${post.slug?.current}`}>{post.title}</a>
          </li>
        ))}
      </ul>
    ) : (
      <p>No posts yet. Create one in Studio first.</p>
    )
  }
</Layout>
