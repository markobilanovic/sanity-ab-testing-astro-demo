---
export type AbTestBadgeEntry = {
  testId: string;
  variantCode: string;
  isControl: boolean;
};

type Props = {
  entries: AbTestBadgeEntry[];
};

const { entries } = Astro.props;

if (!entries || entries.length === 0) {
  return null;
}
---

<aside
  class="ab-badge"
  role="status"
  aria-live="polite"
  aria-label="Active A/B tests"
>
  <div class="ab-badge-header">
    <span class="ab-badge-dot" aria-hidden="true"></span>
    <span class="ab-badge-title">A/B test</span>
    {entries.length > 1 && (
      <span class="ab-badge-count">{entries.length}</span>
    )}
  </div>

  <ul class="ab-badge-list">
    {entries.map((entry) => (
      <li class="ab-badge-item">
        <span class="ab-badge-test" title={entry.testId}>{entry.testId}</span>
        <span
          class:list={[
            "ab-badge-variant",
            entry.isControl ? "is-control" : "is-variant",
          ]}
        >
          {entry.isControl ? (
            "control"
          ) : (
            <>
              variant
              <span class="ab-badge-code">{entry.variantCode}</span>
            </>
          )}
        </span>
      </li>
    ))}
  </ul>
</aside>

<style>
  .ab-badge {
    position: fixed;
    top: 12px;
    right: 12px;
    z-index: 1000;
    min-width: 180px;
    max-width: 280px;
    padding: 10px 12px;
    background: rgba(15, 23, 42, 0.92);
    color: #e2e8f0;
    border: 1px solid rgba(148, 163, 184, 0.25);
    border-radius: 10px;
    box-shadow:
      0 4px 10px rgba(0, 0, 0, 0.15),
      0 1px 2px rgba(0, 0, 0, 0.08);
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    font-size: 12px;
    line-height: 1.35;
    backdrop-filter: saturate(180%) blur(8px);
    -webkit-backdrop-filter: saturate(180%) blur(8px);
    pointer-events: auto;
  }

  .ab-badge-header {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 6px;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #94a3b8;
    font-weight: 600;
  }

  .ab-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.18);
  }

  .ab-badge-title {
    flex: 1;
  }

  .ab-badge-count {
    padding: 1px 6px;
    border-radius: 999px;
    background: rgba(148, 163, 184, 0.18);
    color: #cbd5e1;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0;
  }

  .ab-badge-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 6px;
  }

  .ab-badge-item {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 8px;
  }

  .ab-badge-test {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11.5px;
    font-weight: 600;
    color: #f1f5f9;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ab-badge-variant {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .ab-badge-variant.is-control {
    background: rgba(148, 163, 184, 0.18);
    color: #cbd5e1;
    border: 1px solid rgba(148, 163, 184, 0.25);
  }

  .ab-badge-variant.is-variant {
    background: rgba(59, 130, 246, 0.18);
    color: #93c5fd;
    border: 1px solid rgba(59, 130, 246, 0.35);
  }

  .ab-badge-code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-weight: 700;
    text-transform: none;
    letter-spacing: 0;
    color: #f8fafc;
    opacity: 0.9;
  }

  @media print {
    .ab-badge {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .ab-badge {
      top: 8px;
      right: 8px;
      left: 8px;
      max-width: none;
    }
  }
</style>
